---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;

const toolkits = (await getCollection('toolkits')).sort(
  (a, b) => a.slug.localeCompare(b.slug)
);

// Governance cards — 5 docs, mix of standalone .astro pages (HTML originals) and md collection entries
const govCards = [
  { slug: 'overview', code: '制度導讀', name: 'Operating Model Overview', desc: '內容推廣的運作藍圖：橫切守門、以作品與貢獻肯認、分散式治理、跨組 Pod、四個建構塊。新成員理解整體制度的起點。' },
  { slug: 'charter', code: '工作章程', name: 'Working Charter', desc: '工作公約與七張口袋卡的完整章程版：當責、Pod 成立與解散、紅線攔截、喘息與退出的程序細節。' },
  { slug: 'group-cards', code: '六組導覽卡', name: 'Six Groups Guide', desc: '六個內容小組的職能總覽：什麼時候找哪一組、各組的三級難度路徑、如何協作。跨組協作的入口。' },
  { slug: 'covenant', code: '工作公約', name: 'Working Covenant', desc: '六組共同的十二條做事方式與兩個底線：承諾自訂、一事一 DRI、對外作品要 Pod、紅線即時攔、喘息與退出皆走流程。' },
  { slug: 'pocket-cards', code: '口袋卡', name: 'Pocket Cards', desc: '工作公約十二條的程序展開版，七張獨立卡片：Pod 成立、紅線攔截、喘息、季度 Memo、站會清單、退出轉籍、新血評估。' },
].map(c => ({ ...c, href: `${baseUrl}governance/${c.slug}/`, accent: '#26A7B0' }));

const tkCards = toolkits.map(t => ({
  href: `${baseUrl}toolkits/${t.slug}/`,
  code: t.data.code,
  name: t.data.name,
  nameEn: t.data.nameEn,
  desc: t.data.tagline,
  accent: t.data.heroFrom,
}));
---

<BaseLayout title="GPS 內容推廣文件總集">
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">GPS 內容推廣 · 文件總集 · Document Set</div>
      <h1>內容推廣文件總集</h1>
      <p class="hero-sub">五份治理文件加六本組別 Toolkit，集中一處、可全文檢索。搜尋任何專案、閘門、章節或關鍵詞，直達對應文件。</p>
      <div class="hero-meta">
        <span>資訊更新 2026-06</span><span>·</span>
        <span>11 份文件</span><span>·</span>
        <span>由現任主理人擬定</span>
      </div>
    </div>
  </header>

  <main id="main">
    <section class="search-section">
      <div id="search" class="search-mount"></div>
    </section>

    <section class="pdf-section">
      <h2 class="section-title">下載 PDF</h2>
      <p class="section-hint">螢幕閱讀版（字型不 embed，檔案輕量）。需要列印請使用全集版。</p>
      <div class="pdf-grid">
        <a href={`${baseUrl}pdf/full-set.pdf`} class="pdf-tile" download>
          <div class="pdf-tile-label">全集</div>
          <div class="pdf-tile-desc">五份治理 + 六本 Toolkit 合一</div>
          <div class="pdf-tile-meta">11 份 · 全本</div>
        </a>
        <a href={`${baseUrl}pdf/governance.pdf`} class="pdf-tile" download>
          <div class="pdf-tile-label">治理文件</div>
          <div class="pdf-tile-desc">制度導讀、章程、導覽卡、公約、口袋卡</div>
          <div class="pdf-tile-meta">5 份</div>
        </a>
        <a href={`${baseUrl}pdf/toolkits.pdf`} class="pdf-tile" download>
          <div class="pdf-tile-label">組別 Toolkit</div>
          <div class="pdf-tile-desc">CS2-01 文字敘事至 CS2-06 服務體驗</div>
          <div class="pdf-tile-meta">6 本</div>
        </a>
      </div>
    </section>

    <section class="upstream-section">
      <div class="upstream-header">
        <span class="upstream-badge">
          <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M2 9 L6 3 L10 9" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Upstream Canon · 上游引用
        </span>
        <span class="upstream-title">品牌 Foundation · 教義體系</span>
      </div>
      <p class="upstream-intro">
        此區為 GPS 品牌教義的<strong>單一真相</strong>，由獨立站點維護。下游內容推廣依此 canon 執行——<strong>實作不重新定義 canon</strong>。在 toolkit 內遇到品牌定位、價值、語氣相關決策時，回到此處查證。建議按 Foundation → Narratives 順序閱讀。
      </p>
      <div class="upstream-grid">
        <a href="https://gps-brand-reconstruction.vercel.app/" target="_blank" rel="noopener" class="canon-card">
          <div class="canon-card-eyebrow">Foundation · v3.1</div>
          <div class="canon-card-name">Brand Reconstruction</div>
          <div class="canon-card-name-en">Vision · Mission · Five Pillars</div>
          <p class="canon-card-desc">全球實體安全團隊品牌的策略重建——從企業安全的管制者，轉位為台積同仁與他們所在意的人的個人安全夥伴。</p>
          <div class="canon-card-meta"><strong>BILINGUAL · ZH/EN</strong> · 完整品牌策略基礎</div>
        </a>
        <a href="https://gps-brand-narratives.vercel.app/" target="_blank" rel="noopener" class="canon-card">
          <div class="canon-card-eyebrow">Narratives · v1.3</div>
          <div class="canon-card-name">Brand Narratives</div>
          <div class="canon-card-name-en">Stories the brand already lives by</div>
          <p class="canon-card-desc">起源故事、品牌宣言、五大支柱實踐敘事、三年弧線錨點，以及給 Director、Section Head、第一線同仁的分眾語氣版本。</p>
          <div class="canon-card-meta"><strong>12 NARRATIVES · BILINGUAL</strong></div>
        </a>
      </div>
    </section>

    <section class="cards-section">
      <div class="section-label">
        <span class="section-label-text">治理文件 · Governance</span>
        <span class="section-label-line"></span>
        <span class="section-label-count">5 份</span>
      </div>
      <div class="card-grid">
        {govCards.map(c => (
          <a href={c.href} class="doc-card" style={`--card-accent: ${c.accent}`}>
            <div class="doc-card-top">
              <span class="doc-card-code">{c.code}</span>
              <svg class="doc-card-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 9 H13 M9 5 L13 9 L9 13" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="doc-card-name">{c.name}</h3>
            <p class="doc-card-desc">{c.desc}</p>
          </a>
        ))}
      </div>

      <div class="section-label">
        <span class="section-label-text">組別 Toolkit · Six Groups</span>
        <span class="section-label-line"></span>
        <span class="section-label-count">6 本</span>
      </div>
      <div class="card-grid">
        {tkCards.map(c => (
          <a href={c.href} class="doc-card" style={`--card-accent: ${c.accent}`}>
            <div class="doc-card-top">
              <span class="doc-card-code">{c.code}</span>
              <svg class="doc-card-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 9 H13 M9 5 L13 9 L9 13" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="doc-card-name">{c.name}</h3>
            <p class="doc-card-en">{c.nameEn}</p>
            <p class="doc-card-desc">{c.desc}</p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-row">
      <span class="footer-meta">GPS 內容推廣文件總集 · 資訊更新 2026-06 · 由現任主理人擬定</span>
      <span class="footer-brand">Before you need it. · 在您需要之前。</span>
    </div>
  </footer>
</BaseLayout>

<link rel="stylesheet" href="/gps-content-promotion/pagefind/pagefind-ui.css" />
<script is:inline src="/gps-content-promotion/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', function() {
    if (typeof PagefindUI === 'undefined') return;
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      excerptLength: 30,
      resetStyles: false,
      translations: {
        placeholder: '搜尋文件、專案、閘門、章節⋯⋯（例如：憑證、術語表、CPTED、旅程地圖）',
        clear_search: '清除',
        load_more: '載入更多',
        search_label: '搜尋全部文件',
        filters_label: '篩選',
        zero_results: '找不到「[SEARCH_TERM]」相關內容',
        many_results: '找到 [COUNT] 個結果',
        one_result: '找到 1 個結果',
        searching: '搜尋「[SEARCH_TERM]」中…',
      },
    });
  });
</script>

<style>
.hero {
  background: linear-gradient(135deg, #26A7B0 0%, #1F8A92 55%, #574A63 130%);
  color: #fff;
  padding: 64px 40px 56px;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: "";
  position: absolute;
  right: -80px;
  top: -80px;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  background: rgba(255, 255, 255, .06);
}
.hero-inner {
  max-width: var(--container);
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.hero-eyebrow {
  font-size: .72rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  font-weight: 700;
  opacity: .82;
  margin-bottom: 18px;
}
.hero h1 {
  font-size: 2.4rem;
  font-weight: 800;
  letter-spacing: -.015em;
  margin-bottom: 14px;
  line-height: 1.2;
}
.hero-sub {
  font-size: 1.05rem;
  opacity: .94;
  max-width: 720px;
  margin-bottom: 26px;
}
.hero-meta {
  font-size: .82rem;
  opacity: .72;
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

main {
  max-width: var(--container);
  margin: 0 auto;
  padding: 40px;
}

.search-section {
  margin: -28px 0 36px;
  position: relative;
  z-index: 5;
}
.search-mount {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-hero);
  padding: 14px;
}
.search-mount :global(.pagefind-ui__search-input) {
  font-family: var(--font-cjk);
  font-size: 1rem;
  border-radius: var(--radius);
  background: var(--paper);
  border: 1px solid var(--line);
}

.pdf-section {
  margin-bottom: 44px;
  padding: 26px 28px;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
}
.section-title {
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 4px;
}
.section-hint {
  font-size: .82rem;
  color: var(--muted);
  margin-bottom: 18px;
}
.pdf-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 14px;
}
.pdf-tile {
  display: block;
  padding: 18px 20px;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--ink);
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
}
.pdf-tile:hover {
  transform: translateY(-2px);
  border-color: var(--turquoise);
  box-shadow: var(--shadow);
}
.pdf-tile-label {
  font-size: 1rem;
  font-weight: 800;
  color: var(--turquoise-700);
  margin-bottom: 4px;
}
.pdf-tile-desc {
  font-size: .85rem;
  color: var(--ink-soft);
  margin-bottom: 10px;
  line-height: 1.5;
}
.pdf-tile-meta {
  font-size: .72rem;
  color: var(--muted);
  letter-spacing: .05em;
}

/* ===== 上游引用區塊 ===== */
.upstream-section {
  margin-bottom: 44px;
  padding: 28px 30px;
  background: linear-gradient(135deg, #FAFAFB 0%, #F4F0F5 100%);
  border: 1px solid var(--copper-light);
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
}
.upstream-section::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--copper-deep) 0%, var(--copper-medium) 50%, var(--copper-light) 100%);
}
.upstream-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 6px;
  flex-wrap: wrap;
}
.upstream-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: .7rem;
  font-weight: 800;
  letter-spacing: .12em;
  color: var(--copper-deep);
  background: rgba(110, 95, 124, .1);
  padding: 4px 10px;
  border-radius: 12px;
  text-transform: uppercase;
}
.upstream-badge svg { width: 11px; height: 11px; }
.upstream-title { font-size: 1.05rem; font-weight: 800; color: var(--copper-deep); }
.upstream-intro {
  font-size: .88rem;
  color: var(--ink-soft);
  margin-bottom: 22px;
  max-width: 820px;
  line-height: 1.7;
}
.upstream-intro strong { color: var(--copper-deep); font-weight: 700; }
.upstream-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 14px;
}
.canon-card {
  display: block;
  background: var(--surface);
  border: 1px solid var(--copper-light);
  border-radius: var(--radius);
  padding: 20px 22px;
  text-decoration: none;
  color: var(--ink);
  position: relative;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
}
.canon-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(110, 95, 124, .16);
  border-color: var(--copper-deep);
}
.canon-card::after {
  content: "↗";
  position: absolute;
  top: 18px;
  right: 20px;
  font-size: 1rem;
  color: var(--copper-medium);
  transition: transform var(--transition), color var(--transition);
}
.canon-card:hover::after { color: var(--copper-deep); transform: translate(2px, -2px); }
.canon-card-eyebrow {
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .08em;
  color: var(--copper-medium);
  margin-bottom: 6px;
  text-transform: uppercase;
}
.canon-card-name { font-size: 1.1rem; font-weight: 800; color: var(--copper-deep); margin-bottom: 4px; letter-spacing: -.01em; }
.canon-card-name-en { font-size: .78rem; color: var(--muted); font-style: italic; margin-bottom: 12px; }
.canon-card-desc { font-size: .85rem; color: var(--ink-soft); line-height: 1.65; margin-bottom: 12px; }
.canon-card-meta { font-size: .72rem; color: var(--muted); letter-spacing: .03em; padding-top: 10px; border-top: 1px dashed var(--line); }
.canon-card-meta strong { color: var(--copper-medium); font-weight: 600; }

.section-label {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 38px 0 20px;
}
.section-label-text {
  font-size: .78rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--ink-soft);
  white-space: nowrap;
}
.section-label-line {
  flex: 1;
  height: 1px;
  background: var(--line);
}
.section-label-count {
  font-size: .74rem;
  color: var(--muted);
  font-weight: 600;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 16px;
}

.doc-card {
  display: block;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 22px;
  text-decoration: none;
  color: var(--ink);
  position: relative;
  overflow: hidden;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
}
.doc-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: var(--card-accent);
  opacity: .85;
}
.doc-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
  border-color: var(--card-accent);
}
.doc-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}
.doc-card-code {
  font-size: .74rem;
  font-weight: 800;
  letter-spacing: .04em;
  color: var(--card-accent);
  background: color-mix(in srgb, var(--card-accent) 12%, white);
  padding: 4px 11px;
  border-radius: 6px;
}
.doc-card-arrow {
  color: var(--muted);
  transition: transform var(--transition), color var(--transition);
}
.doc-card:hover .doc-card-arrow {
  color: var(--card-accent);
  transform: translate(3px, -3px);
}
.doc-card-name {
  font-size: 1.18rem;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 3px;
  letter-spacing: -.01em;
}
.doc-card-en {
  font-size: .74rem;
  color: var(--muted);
  font-weight: 600;
  letter-spacing: .03em;
  margin-bottom: 12px;
}
.doc-card-name:last-of-type {
  margin-bottom: 12px;
}
.doc-card-desc {
  font-size: .86rem;
  color: var(--ink-soft);
  line-height: 1.68;
}

.site-footer {
  max-width: var(--container);
  margin: 30px auto 0;
  padding: 30px 40px 50px;
  border-top: 1px solid var(--line);
}
.footer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 14px;
}
.footer-meta {
  font-size: .8rem;
  color: var(--muted);
}
.footer-brand {
  font-size: .82rem;
  color: var(--ink-soft);
  font-weight: 600;
}

@media (max-width: 720px) {
  .hero { padding: 48px 22px 42px; }
  .hero h1 { font-size: 1.9rem; }
  main { padding: 30px 22px; }
  .card-grid { grid-template-columns: 1fr; }
}
</style>
